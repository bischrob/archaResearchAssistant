# Core runtime
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# API auth (optional; if set, sync/ingest endpoints require Bearer token)
API_BEARER_TOKEN=

# Metadata source: zotero (default) or paperpile (legacy fallback)
METADATA_BACKEND=zotero
METADATA_REQUIRE_MATCH=1

# Zotero paths (recommended for zotero backend)
ZOTERO_DB_PATH=
ZOTERO_STORAGE_ROOT=

# Legacy Paperpile fallback
PAPERPILE_JSON=Paperpile.json

# PDF source defaults
NEXTCLOUD_PDF_ROOT=
PDF_SOURCE_DIR=

# Ingest processing
CITATION_PARSER=qwen_refsplit_anystyle
CITATION_MIN_QUALITY=0.35
CHUNK_STRIP_PAGE_NOISE=1
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=45

# ZIP-embedded PDF scan support
ZIP_PDF_ENABLE=1
ZIP_PDF_CACHE_DIR=.cache/zotero_zip_pdf_cache

# Optional local Qwen overrides
QWEN3_MODEL_PATH=
QWEN3_CITATION_ADAPTER_PATH=
QWEN3_QUERY_ADAPTER_PATH=

# Query preprocessing backend: openai or qwen
QUERY_PREPROCESS_BACKEND=openai
